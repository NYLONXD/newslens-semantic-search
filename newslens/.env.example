# Copy this file to .env and fill in values

# Endee server URL (use http://localhost:8080 for local dev, http://endee:8080 inside Docker)
ENDEE_HOST=http://localhost:8080

# Leave empty for no auth (recommended for local dev)
ENDEE_AUTH_TOKEN=

# Name of the Endee index to create/use
ENDEE_INDEX_NAME=news_articles

# Path to your news CSV file
DATA_CSV_PATH=./data/sample_articles.csv

# Embedding model (all-MiniLM-L6-v2 is fast + free, 384 dimensions)
EMBEDDING_MODEL=all-MiniLM-L6-v2
